# Copy to .env and adjust. Optional keys improve rate limits or abstract coverage.
#
# Omit DATABASE_URL to use backend/research_companion.db (stable path regardless of cwd).
# DATABASE_URL=postgresql+psycopg://...

NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# LLM (Cerebras)
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama3.1-8b

# LLM routing (LangChain providers)
# auto: prefer Google (if key set), then local Ollama
LLM_PROVIDER=auto
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash-lite
# Hosted Ollama (ollama.com): set OLLAMA_BASE_URL=https://ollama.com and OLLAMA_API_KEY (Bearer). Local ignores the key.
# OLLAMA_MODEL must match a model on that server: local `ollama list` or `ollama pull llama3.2`; cloud = name from ollama.com.
OLLAMA_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:latest
LANGSMITH_API_KEY=

# Research APIs (optional)
RESEARCH_CONTACT_EMAIL=
# https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=
OPENALEX_API_KEY=
# CORE (https://core.ac.uk/services/api) — optional; enriches OA abstracts when set
CORE_API_KEY=
